# ============================================================
# FinLife — Environment Variables
# Kopiere diese Datei zu .env und fülle die Werte aus.
# ============================================================

# --- Supabase (Pflicht) -------------------------------------
# Frontend (Vite-exposed, müssen mit VITE_ beginnen)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"

# Spiegel für lokale Skripte / Edge-Function-Tests (optional)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"

# ============================================================
# Die folgenden Werte werden NICHT im Frontend benötigt.
# Sie gehören in das Supabase-Dashboard:
#   Project Settings → Edge Functions → Secrets
# ============================================================
#
# SUPABASE_SERVICE_ROLE_KEY   — Admin-Funktionen, Lead-Eingang
# LOVABLE_API_KEY             — KI-Endpunkte (Coach, Xray, 3a, Extract)
# STRIPE_SECRET_KEY           — Premium-Abo (Checkout, Portal, Sync)
